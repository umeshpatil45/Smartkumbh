<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KumbhVerse | Live Crowd Analytics</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary: #ff6a00;
            --bg-dark: #050506;
            --sidebar-bg: #0c0c0e;
            --card-glass: rgba(255, 255, 255, 0.03);
            --border-glass: rgba(255, 255, 255, 0.08);
            --danger: #ff4d4d;
            --warning: #f1c40f;
            --success: #2ecc71;
        }

        body {
            background-color: var(--bg-dark);
            color: #ffffff;
            font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0;
            display: flex;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* Sidebar */
        .sidebar { 
            width: 260px; 
            height: 100vh; 
            background: var(--sidebar-bg); 
            border-right: 1px solid var(--border-glass); 
            position: fixed; 
            padding: 30px 20px;
            z-index: 1000;
        }

        .brand-logo { 
            font-size: 22px; 
            font-weight: 800; 
            color: var(--primary);
            text-decoration: none; 
            display: block; 
            margin-bottom: 40px; 
            letter-spacing: 1px;
        }

        .nav-link { 
            color: rgba(255,255,255,0.5); 
            padding: 12px 15px; 
            border-radius: 10px; 
            display: flex; 
            align-items: center; 
            gap: 12px; 
            text-decoration: none; 
            margin-bottom: 8px;
            transition: 0.3s;
        }

        .nav-link:hover, .nav-link.active { 
            background: rgba(255, 106, 0, 0.1); 
            color: var(--primary); 
        }

        .main-content { 
            margin-left: 260px; 
            padding: 40px; 
            width: calc(100% - 260px);
            min-height: 100vh;
        }

        .premium-card { 
            background: var(--card-glass); 
            border: 1px solid var(--border-glass); 
            border-radius: 20px; 
            padding: 20px; 
            backdrop-filter: blur(15px);
            height: 100%;
            margin-bottom: 20px;
        }

        #map { 
            height: 400px; 
            width: 100%;
            border-radius: 15px; 
            border: 1px solid var(--border-glass); 
        }

        .stat-value { font-size: 2.5rem; font-weight: 800; color: var(--primary); transition: 0.5s; }
        .stat-label { font-size: 0.8rem; color: rgba(255,255,255,0.5); text-transform: uppercase; }

        /* Pulse Animation */
        .live-dot {
            height: 10px; width: 10px;
            background-color: var(--success);
            border-radius: 50%;
            display: inline-block;
            margin-right: 8px;
            box-shadow: 0 0 10px var(--success);
            animation: pulse 1.5s infinite;
        }

        @keyframes pulse {
            0% { transform: scale(0.95); opacity: 0.7; }
            70% { transform: scale(1.2); opacity: 1; }
            100% { transform: scale(0.95); opacity: 0.7; }
        }

        .hotzone-item { 
            padding: 15px; border-radius: 15px; 
            background: rgba(255,255,255,0.02); 
            border-left: 4px solid var(--primary);
            height: 100%;
        }

        .chart-container { position: relative; height: 250px; width: 100%; }

        /* --- NEW: ATTRACTIVE CUSTOM POPUP (Toast) --- */
        #customPopup {
            position: fixed;
            bottom: -100px;
            right: 30px;
            background: rgba(46, 204, 113, 0.15);
            border: 1px solid var(--success);
            backdrop-filter: blur(15px);
            color: white;
            padding: 15px 25px;
            border-radius: 15px;
            display: flex;
            align-items: center;
            gap: 15px;
            z-index: 2000;
            transition: all 0.5s cubic-bezier(0.68, -0.55, 0.265, 1.55);
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        #customPopup.show {
            bottom: 30px;
        }

        .popup-icon {
            width: 35px;
            height: 35px;
            background: var(--success);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
            box-shadow: 0 0 15px var(--success);
        }

        @media (max-width: 992px) {
            .sidebar { width: 70px; padding: 20px 10px; }
            .sidebar span, .brand-logo { display: none; }
            .main-content { margin-left: 70px; width: calc(100% - 70px); }
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <a href="#" class="brand-logo">KUMBHVERSE</a>
        <nav>
            <a href="/admin-dashboard" class="nav-link"><i class="fa-solid fa-house"></i> <span>Overview</span></a>
            <a href="/admin-officers" class="nav-link"><i class="fa-solid fa-shield-halved"></i> <span>Officers</span></a>
            <a href="/admin-crowd" class="nav-link active"><i class="fa-solid fa-users-viewfinder"></i> <span>Crowd Analytics</span></a>
            <a href="/admin-alerts" class="nav-link"><i class="fa-solid fa-tower-broadcast"></i> <span>Emergency</span></a>
            <div class="mt-5 pt-5">
                <a href="/logout" class="nav-link text-danger"><i class="fa-solid fa-power-off"></i> Logout</a>
            </div>
        </nav>
    </div>

    <div class="main-content">
        <div class="mb-5 d-flex justify-content-between align-items-center">
            <div>
                <h1 class="fw-800 m-0">Crowd Intelligence</h1>
                <p class="text-white-50"><span class="live-dot"></span> System Live: Monitoring Nashik Sectors</p>
            </div>
            <button id="downloadBtn" class="btn btn-outline-light btn-sm rounded-pill px-3">
                <i class="fa-solid fa-download me-2"></i> Download Report
            </button>
        </div>

        <div class="row g-4 mb-4">
            <div class="col-lg-4">
                <div class="premium-card text-center">
                    <span class="stat-label">Total Live Crowd</span>
                    <div class="stat-value" id="crowdCount">1,42,500</div>
                    <div class="small text-success mb-3" id="liveTrend"><i class="fa-solid fa-arrow-trend-up"></i> Calculating...</div>
                    <hr style="border-color: var(--border-glass)">
                    <h6 class="fw-bold mb-3 text-white-50">Real-time Inflow Rate</h6>
                    <div class="chart-container">
                        <canvas id="trafficChart"></canvas>
                    </div>
                </div>
            </div>
            <div class="col-lg-8">
                <div class="premium-card">
                    <h6 class="fw-bold mb-3">Live Geographical Density Map</h6>
                    <div id="map"></div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <div class="premium-card">
                    <h6 class="fw-bold mb-4">Real-time Safety Recommendations</h6>
                    <div class="row g-3">
                        <div class="col-md-4">
                            <div class="hotzone-item" style="border-left-color: var(--danger);">
                                <div class="fw-bold text-danger mb-1">RAM KUND GATE 2</div>
                                <p class="small text-white-50 m-0">Density high. Action: Open exit gate 4 immediately.</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="hotzone-item" style="border-left-color: var(--warning);">
                                <div class="fw-bold text-warning mb-1">PARKING SECTOR 4</div>
                                <p class="small text-white-50 m-0">88% Occupied. Redirecting to backup parking.</p>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="hotzone-item" style="border-left-color: var(--success);">
                                <div class="fw-bold text-success mb-1">MAIN GHAT AREA</div>
                                <p class="small text-white-50 m-0">Flow stable. No immediate action required.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="customPopup">
        <div class="popup-icon"><i class="fa-solid fa-check"></i></div>
        <div>
            <div class="fw-bold">Report Ready!</div>
            <div class="small text-white-50">Intelligence data downloaded successfully.</div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    
    <script>
        // 1. Initialize Map
        const map = L.map('map').setView([19.9935, 73.7915], 14);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png').addTo(map);
        const marker = L.circle([19.9935, 73.7915], { color: 'red', radius: 400 }).addTo(map).bindPopup("Ram Kund: High Density");

        // 2. Initialize Chart
        const ctx = document.getElementById('trafficChart').getContext('2d');
        const trafficChart = new Chart(ctx, {
            type: 'line',
            data: {
                labels: ['10s ago', '8s ago', '6s ago', '4s ago', '2s ago', 'Now'],
                datasets: [{
                    label: 'Live Inflow',
                    data: [12000, 13000, 12500, 14000, 14500, 14250],
                    borderColor: '#ff6a00',
                    backgroundColor: 'rgba(255, 106, 0, 0.1)',
                    tension: 0.4,
                    fill: true,
                    pointRadius: 0
                }]
            },
            options: {
                maintainAspectRatio: false,
                plugins: { legend: { display: false } },
                scales: { 
                    y: { display: false, min: 10000, max: 20000 },
                    x: { ticks: { color: '#555' }, grid: { display: false } }
                }
            }
        });

        // 3. LIVE LOGIC
        let currentCount = 142500;
        function updateLiveCrowd() {
            const change = Math.floor(Math.random() * 200) - 50; 
            currentCount += change;
            document.getElementById('crowdCount').innerText = currentCount.toLocaleString();
            const trendEl = document.getElementById('liveTrend');
            if(change > 0) {
                trendEl.innerHTML = `<i class="fa-solid fa-arrow-trend-up"></i> +${change} in last 3s`;
                trendEl.className = "small text-success mb-3";
            } else {
                trendEl.innerHTML = `<i class="fa-solid fa-arrow-trend-down"></i> ${change} in last 3s`;
                trendEl.className = "small text-warning mb-3";
            }
            trafficChart.data.datasets[0].data.shift(); 
            trafficChart.data.datasets[0].data.push(currentCount / 10); 
            trafficChart.update('none'); 
        }
        setInterval(updateLiveCrowd, 3000);

        // --- ENHANCED: DOWNLOAD & CUSTOM POPUP ---
        document.getElementById('downloadBtn').addEventListener('click', function() {
            // Step 1: Prepare Data in English
            const reportDate = new Date().toLocaleString();
            const crowd = document.getElementById('crowdCount').innerText;
            const trend = document.getElementById('liveTrend').innerText;

            const reportContent = `
KUMBHVERSE | LIVE CROWD INTELLIGENCE REPORT
------------------------------------------
Generated On: ${reportDate}
Live Status: ACTIVE (Nashik Sectors)
------------------------------------------

1. DATA ANALYTICS:
   - Current Live Count: ${crowd}
   - Real-time Trend: ${trend}

2. SAFETY ADVISORY & ACTIONS:
   - RAM KUND GATE 2: High Density. Recommendation: Open exit gate 4.
   - PARKING SECTOR 4: 88% Occupied. Recommendation: Redirecting traffic.
   - MAIN GHAT AREA: Stable Flow. No action required.

3. GEOGRAPHICAL SCAN:
   - Monitoring Point: Ram Kund (19.9935° N, 73.7915° E)
   - Sector Integrity: Verified

------------------------------------------
END OF REPORT
            `;

            // Step 2: Handle File Download
            const blob = new Blob([reportContent], { type: 'text/plain' });
            const url = window.URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = `KumbhVerse_Intel_${new Date().getTime()}.txt`;
            document.body.appendChild(a);
            a.click();
            window.URL.revokeObjectURL(url);
            document.body.removeChild(a);

            // Step 3: Trigger Modern Custom Popup
            const popup = document.getElementById('customPopup');
            popup.classList.add('show');

            // Hide after 3.5 seconds
            setTimeout(() => {
                popup.classList.remove('show');
            }, 3500);
        });

    </script>
</body>
</html>