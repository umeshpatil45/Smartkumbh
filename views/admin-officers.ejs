<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KumbhVerse | Officer Management</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary: #ff6a00;
            --bg-dark: #050506;
            --sidebar-bg: #0c0c0e;
            --card-glass: rgba(255, 255, 255, 0.03);
            --border-glass: rgba(255, 255, 255, 0.08);
        }

        body {
            background-color: var(--bg-dark);
            color: #ffffff;
            font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0;
            display: flex;
        }

        /* Sidebar */
        .sidebar {
            width: 280px;
            height: 100vh;
            background: var(--sidebar-bg);
            border-right: 1px solid var(--border-glass);
            position: fixed;
            padding: 30px 20px;
        }

        .brand-logo {
            font-size: 24px;
            font-weight: 800;
            background: linear-gradient(to right, var(--primary), #ff0055);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            text-decoration: none;
            display: block;
            margin-bottom: 40px;
        }

        .nav-link {
            color: rgba(255,255,255,0.5);
            padding: 14px 18px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 15px;
            text-decoration: none;
            transition: 0.3s;
            margin-bottom: 5px;
        }

        .nav-link:hover, .nav-link.active {
            background: rgba(255, 106, 0, 0.1);
            color: var(--primary);
        }

        /* Main Content */
        .main-content {
            margin-left: 280px;
            width: calc(100% - 280px);
            padding: 40px;
        }

        .premium-card {
            background: var(--card-glass);
            border: 1px solid var(--border-glass);
            border-radius: 24px;
            padding: 30px;
            backdrop-filter: blur(10px);
        }

        /* Table Style */
        .officer-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 10px;
        }

        .officer-table tr {
            background: rgba(255,255,255,0.02);
        }

        .officer-table td {
            padding: 20px;
            border-top: 1px solid var(--border-glass);
            border-bottom: 1px solid var(--border-glass);
        }

        .officer-table td:first-child { border-left: 1px solid var(--border-glass); border-top-left-radius: 15px; border-bottom-left-radius: 15px; }
        .officer-table td:last-child { border-right: 1px solid var(--border-glass); border-top-right-radius: 15px; border-bottom-right-radius: 15px; }

        .avatar {
            width: 45px;
            height: 45px;
            background: var(--primary);
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            text-transform: uppercase;
        }

        .status-pill {
            padding: 6px 14px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
        }

        .status-approved { background: rgba(46, 204, 113, 0.1); color: #2ecc71; border: 1px solid #2ecc71; }
        .status-pending { background: rgba(241, 196, 15, 0.1); color: #f1c40f; border: 1px solid #f1c40f; }

        .btn-action {
            border: none;
            padding: 8px 16px;
            border-radius: 10px;
            font-size: 12px;
            font-weight: 600;
            transition: 0.2s;
        }

        .btn-approve { background: #2ecc71; color: white; }
        .btn-remove { background: rgba(255, 77, 77, 0.1); color: #ff4d4d; border: 1px solid #ff4d4d; }
        .btn-action:hover { transform: translateY(-2px); opacity: 0.9; }
    </style>
</head>
<body>

    <div class="sidebar">
        <a href="#" class="brand-logo">KUMBHVERSE AI</a>
        <nav>
            <a href="/admin-dashboard" class="nav-link"><i class="fa-solid fa-house"></i> Overview</a>
            <a href="/admin-officers" class="nav-link active"><i class="fa-solid fa-shield-halved"></i> Security Officers</a>
            <a href="/admin-crowd" class="nav-link"><i class="fa-solid fa-users-viewfinder"></i> Crowd Analytics</a>
            <a href="/admin-alerts" class="nav-link"><i class="fa-solid fa-tower-broadcast"></i> Emergency Broadcast</a>
            <div class="mt-5 pt-5">
                <a href="/logout" class="nav-link text-danger"><i class="fa-solid fa-power-off"></i> Logout</a>
            </div>
        </nav>
    </div>

    <div class="main-content">
        <div class="d-flex justify-content-between align-items-center mb-5">
            <div>
                <h1 class="fw-800 m-0">Officer Management</h1>
                <p class="text-white-50">View information and manage all security force personnel.</p>
            </div>
        </div>

        <div class="premium-card">
            <div class="table-responsive">
                <table class="officer-table">
                    <thead>
                        <tr class="text-white-50 small">
                            <th>OFFICER</th>
                            <th>DEPARTMENT</th>
                            <th>STATUS</th>
                            <th class="text-end">ACTIONS</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if(typeof officers !== 'undefined' && officers.length > 0) { %>
                            <% officers.forEach(officer => { %>
                                <tr>
                                    <td>
                                        <div class="d-flex align-items-center gap-3">
                                            <div class="avatar">
                                                <%= (officer.name && officer.name.length > 0) ? officer.name.charAt(0) : 'O' %>
                                            </div>
                                            <div>
                                                <div class="fw-bold"><%= officer.name || 'Unknown Officer' %></div>
                                                <div class="small text-white-50"><%= officer.email || 'No Email' %></div>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="badge bg-dark border border-secondary px-3 py-2 rounded-pill">
                                            <%= officer.department || 'Field Security' %>
                                        </span>
                                    </td>
                                    <td>
                                        <% if(officer.status === 'Approved') { %>
                                            <span class="status-pill status-approved">ACTIVE</span>
                                        <% } else { %>
                                            <span class="status-pill status-pending">PENDING</span>
                                        <% } %>
                                    </td>
                                    <td class="text-end">
                                        <% if(officer.status !== 'Approved') { %>
                                            <form action="/admin/approve/<%= officer._id %>" method="POST" style="display:inline;">
                                                <button type="submit" class="btn-action btn-approve me-2">APPROVE</button>
                                            </form>
                                        <% } %>
                                        <button class="btn-action btn-remove">REMOVE</button>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="4" class="text-center py-5 text-white-50">No officers found in the database.</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        // Real-time update when dashboard data changes
        socket.on('update_dashboard', () => {
            window.location.reload();
        });
    </script>
</body>
</html>