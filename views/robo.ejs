<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KumbhVerse AI - Premium AI Guide</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600&display=swap" rel="stylesheet">
    <meta http-equiv="Content-Security-Policy" content="default-src 'self' https:; script-src 'self' 'unsafe-inline' https:; style-src 'self' 'unsafe-inline' https:; img-src 'self' data: https:; connect-src 'self' https://generativelanguage.googleapis.com;">
    <style>
        :root { 
            --accent: #ff6a00; 
            --accent-dark: #e65c00;
            --bg: #1a0f00; 
            --glass: rgba(15, 8, 0, 0.9); 
        }
        
        body, html { 
            margin: 0; padding: 0; width: 100%; height: 100%;
            color: white; font-family: 'Poppins', sans-serif; 
            overflow: hidden; background: var(--bg);
        }

        .hero-bg {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background-image: 
                linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)),
                url('https://images.unsplash.com/photo-1590050752117-238cb0fb12b1?ixlib=rb-4.0.3&auto=format&fit=crop&w=1600&q=80');
            background-size: cover; background-position: center;
            z-index: -1; transform: scale(1.1); filter: saturate(1.2) blur(2px);
        }

        .back-btn {
            position: absolute; top: 30px; left: 30px;
            background: var(--glass); border: 1px solid rgba(255, 106, 0, 0.4);
            padding: 10px 25px; border-radius: 50px; color: white;
            text-decoration: none; display: flex; align-items: center; gap: 10px;
            font-weight: 500; transition: 0.3s; z-index: 100;
            cursor: pointer; backdrop-filter: blur(10px);
        }
        .back-btn:hover { background: var(--accent); transform: translateX(-5px); border-color: white; }

        #avatar-container { 
            position: absolute; bottom: 0; right: -50px; 
            width: auto; height: 95vh; z-index: 5; 
            pointer-events: none; opacity: 0.85;
        }
        #avatar-container img { height: 100%; width: auto; filter: drop-shadow(0 0 30px black); animation: float 4s ease-in-out infinite; }

        @keyframes float { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-15px); } }

        .chat-container {
            position: absolute; top: 50%; left: 50%;
            transform: translate(-50%, -50%);
            width: 700px; max-width: 90%; z-index: 10;
        }

        .chat-box {
            height: 500px; 
            overflow-y: auto; background: var(--glass); backdrop-filter: blur(20px);
            border-radius: 40px; padding: 40px; 
            border: 2px solid rgba(255, 106, 0, 0.4);
            margin-bottom: 25px; display: flex; flex-direction: column; gap: 20px;
            box-shadow: 0 30px 60px rgba(0,0,0,0.8);
        }

        .message { padding: 18px 25px; border-radius: 25px; font-size: 17px; max-width: 80%; line-height: 1.6; }
        .user { align-self: flex-end; background: linear-gradient(135deg, var(--accent), #ff4500); color: white; }
        .ai { align-self: flex-start; background: rgba(255, 255, 255, 0.1); border-left: 6px solid var(--accent); }

        .input-area { display: flex; gap: 15px; background: white; padding: 15px; border-radius: 80px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); }
        input { flex: 1; border: none; padding-left: 30px; outline: none; font-size: 17px; color: #333; }
        
        .btn-circle { background: var(--accent); border: none; width: 60px; height: 60px; border-radius: 50%; color: white; cursor: pointer; font-size: 22px; transition: 0.3s; display: flex; align-items: center; justify-content: center; }
        .btn-circle:hover { background: var(--accent-dark); transform: scale(1.1); }

        #loader { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: #000; display: flex; flex-direction: column; justify-content: center; align-items: center; z-index: 1000; }
        .loader-text { color: var(--accent); font-size: 2.5rem; font-weight: 600; letter-spacing: 5px; }
    </style>
</head>
<body>

<div id="loader">
    <h1 class="loader-text">WELCOME</h1>
    <p style="color: #888;">Preparing KumbhVerse AI...</p>
</div>

<a href="/" class="back-btn">
    <span>⬅</span> Back to Home
</a>

<div class="hero-bg"></div>

<div id="avatar-container">
    <img src="images/robo.png" alt="Kumbh Guide">
</div>

<div class="chat-container">
    <div class="chat-box" id="chatBox">
        <div class="message ai">Hello! I am your Kumbh Mela AI guide. Please login to start our spiritual journey and explore the divine heritage of Nashik.</div>
    </div>
    <div class="input-area">
        <input type="text" id="userInput" placeholder="Ask me anything...">
        <button class="btn-circle" onclick="startVoice()">🎤</button>
        <button class="btn-circle" onclick="handleText()">➤</button>
    </div>
</div>

<script>
    const GEMINI_API_KEY = "AIzaSyBTUTqeA0squJEhm-HVePkn8M539kgQfxE";
    let isLoggedIn = false; 

    window.onload = () => {
        setTimeout(() => { document.getElementById('loader').style.display = 'none'; }, 1500);
    };

    async function askGemini(query) {
        if (!query) return;
        const chatBox = document.getElementById('chatBox');
        
        const userDiv = document.createElement('div');
        userDiv.className = "message user";
        userDiv.innerText = query;
        chatBox.appendChild(userDiv);

        const loadingDiv = document.createElement('div');
        loadingDiv.className = "message ai";
        loadingDiv.innerText = "...";
        chatBox.appendChild(loadingDiv);
        chatBox.scrollTop = chatBox.scrollHeight;

        if (!isLoggedIn) {
            let responseMsg = "Access Denied. Please login first to interact with the Kumbh Mela Assistant.";
            loadingDiv.innerText = responseMsg;
            speak(responseMsg, "en-US");
            return;
        }

        // Gemini API logic will go here once logged in
    }

    function handleText() {
        const input = document.getElementById('userInput');
        if(input.value.trim() !== "") {
            askGemini(input.value);
            input.value = "";
        }
    }

    function startVoice() {
        const rec = new (window.SpeechRecognition || window.webkitSpeechRecognition)();
        rec.lang = 'en-US'; 
        rec.onresult = (e) => askGemini(e.results[0][0].transcript);
        rec.start();
    }

    function speak(text, lang) {
        window.speechSynthesis.cancel();
        const utterance = new SpeechSynthesisUtterance(text);
        let voices = window.speechSynthesis.getVoices();
        let femaleVoice = voices.find(voice => 
            (voice.name.includes('Female') || voice.name.includes('Google') || voice.name.includes('Zira')) 
            && voice.lang.includes('en')
        );
        if (femaleVoice) utterance.voice = femaleVoice;
        utterance.lang = lang;
        utterance.pitch = 1.2;
        utterance.rate = 1.0;
        window.speechSynthesis.speak(utterance);
    }

    window.speechSynthesis.onvoiceschanged = () => { window.speechSynthesis.getVoices(); };

    document.getElementById('userInput').addEventListener('keypress', (e) => {
        if (e.key === 'Enter') handleText();
    });
</script>
</body>
</html>