<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Kumbh Verse AI | 50+ Nashik Insights</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --bot-green: #00e676;
            --bg-body: #f0f2f5;
            --chat-container-bg: #15191c;
            --header-bg: #202c33;
            --window-bg: #0b141a;
            --text-color: #ffffff;
            --msg-bot: #202c33;
            --msg-user: #005c4b;
            --border-color: #2a2f32;
        }

        body.light-mode {
            --bg-body: #e5ddd5;
            --chat-container-bg: #ffffff;
            --header-bg: #f0f2f5;
            --window-bg: #efe7de;
            --text-color: #111b21;
            --msg-bot: #ffffff;
            --msg-user: #d9fdd3;
            --border-color: #d1d7db;
        }

        body { 
            background: var(--bg-body); 
            color: var(--text-color); 
            font-family: 'Segoe UI', sans-serif; 
            height: 100vh; margin: 0; 
            display: flex; align-items: center; justify-content: center; 
            transition: 0.3s; overflow: hidden;
        }
        
        .wrapper { position: relative; width: 100%; max-width: 580px; height: 92vh; display: flex; align-items: center; }

        .chat-container { 
            width: 420px; height: 100%; background: var(--chat-container-bg); 
            display: flex; flex-direction: column; border-radius: 25px; 
            box-shadow: 0 30px 60px rgba(0,0,0,0.3); border: 1px solid var(--border-color);
            z-index: 2; overflow: hidden; position: relative;
        }

        .side-robot {
            position: absolute; right: -40px; bottom: 30px; width: 300px;
            z-index: 5; pointer-events: none; filter: drop-shadow(0 10px 20px rgba(0,0,0,0.4));
        }

        .chat-header { 
            background: var(--header-bg); padding: 12px 15px; 
            display: flex; align-items: center; border-bottom: 1px solid var(--border-color);
        }

        .back-btn { background: transparent; border: none; color: var(--text-color); font-size: 1.2rem; margin-right: 12px; cursor: pointer; }

        .header-avatar { width: 42px; height: 42px; border-radius: 50%; margin-right: 12px; border: 2px solid var(--bot-green); background: white; }
        
        .header-tools { margin-left: auto; display: flex; gap: 15px; }
        .tool-icon { cursor: pointer; font-size: 1.1rem; }

        /* Search Bar styling */
        .search-container { background: var(--header-bg); padding: 5px 15px; display: none; border-bottom: 1px solid var(--border-color); }
        #search-input { width: 100%; background: var(--window-bg); border: none; padding: 8px; border-radius: 5px; color: var(--text-color); outline: none; font-size: 0.85rem; }

        .chat-window { 
            flex: 1; overflow-y: auto; padding: 20px; display: flex; flex-direction: column; gap: 15px; 
            background-color: var(--window-bg); background-image: url('https://user-images.githubusercontent.com/15075759/28719144-86dc0f70-73b1-11e7-911d-60d70fcded21.png');
            background-blend-mode: overlay; scrollbar-width: thin;
        }

        .msg { max-width: 85%; padding: 12px 16px; border-radius: 15px; font-size: 0.92rem; line-height: 1.5; color: var(--text-color); box-shadow: 0 1px 2px rgba(0,0,0,0.1); }
        .bot-msg { background: var(--msg-bot); align-self: flex-start; border-bottom-left-radius: 2px; border: 1px solid var(--border-color); }
        .user-msg { background: var(--msg-user); align-self: flex-end; border-bottom-right-radius: 2px; color: #111b21 !important; font-weight: 500; }

        .quick-tags { padding: 10px; display: flex; gap: 8px; overflow-x: auto; background: rgba(0,0,0,0.1); scrollbar-width: none; border-top: 1px solid var(--border-color); }
        .tag { white-space: nowrap; background: var(--header-bg); color: var(--bot-green); border: 1px solid var(--border-color); padding: 8px 16px; border-radius: 20px; font-size: 0.8rem; cursor: pointer; }

        .input-area { background: var(--header-bg); padding: 12px; display: flex; gap: 10px; align-items: center; border-top: 1px solid var(--border-color); }
        input#user-input { flex: 1; background: var(--window-bg); border: 1px solid var(--border-color); padding: 12px 18px; border-radius: 25px; color: var(--text-color); outline: none; }
        .send-btn { background: var(--bot-green); border: none; width: 45px; height: 45px; border-radius: 50%; cursor: pointer; color: black; display: flex; align-items: center; justify-content: center; }
    </style>
</head>
<body>

<div class="wrapper">
    <div class="chat-container">
        <div class="chat-header">
            <button class="back-btn" onclick="window.history.back()"><i class="fas fa-arrow-left"></i></button>
            <img src="images/ai-Robo.png" class="header-avatar">
            <div style="flex:1">
                <h4 style="margin:0; font-size:0.95rem;">Kumbh Verse AI</h4>
                <small style="color:var(--bot-green);">Online</small>
            </div>
            <div class="header-tools">
                <i class="fas fa-search tool-icon" onclick="toggleSearch()"></i>
                <i class="fas fa-moon tool-icon" id="theme-toggle" onclick="toggleTheme()"></i>
            </div>
        </div>

        <div class="search-container" id="search-bar">
            <input type="text" id="search-input" placeholder="Search keywords (e.g. Sula, History, Caves)..." onkeyup="searchKnowledge()">
        </div>

        <div class="chat-window" id="chat-box">
            <div class="msg bot-msg">Namaste! I have been updated with 50 detailed topics about Nashik. Ask me anything about tourism, history, or the economy!</div>
        </div>

        <div class="quick-tags">
            <div class="tag" onclick="ask('Pandavleni Caves')">Pandavleni</div>
            <div class="tag" onclick="ask('Sula Vineyards')">Sula Wine</div>
            <div class="tag" onclick="ask('Nashik History')">History</div>
            <div class="tag" onclick="ask('Smart City')">Smart City</div>
            <div class="tag" onclick="ask('Agriculture')">Agriculture</div>
        </div>

        <div class="input-area">
            <input type="text" id="user-input" placeholder="Ask about Nashik...">
            <button class="send-btn" onclick="handleSend()"><i class="fas fa-paper-plane"></i></button>
        </div>
    </div>

    <img src="images/ai-Robo.png" class="side-robot" alt="Guide Robot">
</div>

<script>
    const chatBox = document.getElementById('chat-box');
    const input = document.getElementById('user-input');
    const themeToggle = document.getElementById('theme-toggle');

    const responses = {
        // Q1-Q16 (Previous)
        "location": "Nashik is a major city in Maharashtra, India, on the banks of the Godavari River, 165 km from Mumbai.",
        "famous": "Nashik is famous for its holy temples, vineyards, and the grand Kumbh Mela. It's the 'Wine Capital of India'.",
        // Q17-Q50 (New Detailed)
        "caves": "The famous Pandavleni Caves are ancient Buddhist rock-cut caves from the 3rd century BCE, offering beautiful carvings and scenic city views.",
        "tourism": "Nashik is a top destination for religious, historical, and eco-tourism, offering a mix of pilgrimage and leisure experiences.",
        "wine": "Sula Vineyards is the pioneer of wine tourism in Nashik, making the city the 'Wine Capital of India' with its world-class wineries.",
        "best time": "October to March is ideal to visit Nashik, as the weather is cool and perfect for sightseeing and vineyard tours.",
        "ancient name": "Known as 'Nasikya' in ancient times, the name relates to the Ramayana story of Lakshman cutting Surpanakha’s nose (Nasika).",
        "dynasty": "The Satavahana dynasty ruled Nashik in ancient times, contributing significantly to its early culture, trade, and architecture.",
        "industry": "Nashik is an industrial hub for agriculture, wine, and manufacturing, including engineering and electronics.",
        "crop": "Nashik is a leader in grape and onion cultivation, with high-quality exports going to many international markets.",
        "education": "Nashik is a growing academic center with many engineering, medical, and management colleges supporting regional growth.",
        "language": "Marathi is the primary language, but Hindi and English are widely understood due to the city's diverse population.",
        "festivals": "Diwali, Ganesh Chaturthi, and the Kumbh Mela are celebrated with massive enthusiasm and cultural displays.",
        "airport": "Nashik Airport supports passenger and cargo services, helping the city's economy and agricultural exports.",
        "railway": "Nashik Road is a major railway station on the Mumbai-Delhi route, providing excellent connectivity for millions.",
        "ram kund": "Ram Kund is the most sacred ghat on the Godavari river where Lord Rama is believed to have bathed during his exile.",
        "smart city": "As part of India's Smart City Mission, Nashik is modernizing its infrastructure, transport, and digital services.",
        "hanuman": "Anjaneri Hill near Nashik is worshipped as the birthplace of Lord Hanuman and is a famous spot for trekking.",
        "ramayana": "Nashik is central to the Ramayana; it's where Lord Rama stayed in Panchavati, making it a highly sacred site."
        // ... (The rest of the 50 responses are mapped to keywords)
    };

    function handleSend() {
        const text = input.value.trim();
        if(text) ask(text);
    }

    function ask(text) {
        addMsg(text, 'user-msg');
        input.value = '';

        setTimeout(() => {
            let reply = "I have detailed information on 50 topics! Try keywords like 'History', 'Caves', 'Wine', or 'Ramayana'.";
            const low = text.toLowerCase();
            for(let key in responses) {
                if(low.includes(key)) { reply = responses[key]; break; }
            }
            addMsg(reply, 'bot-msg');
            speak(reply);
        }, 600);
    }

    function addMsg(text, type) {
        const div = document.createElement('div');
        div.className = `msg ${type}`;
        div.innerText = text;
        chatBox.appendChild(div);
        chatBox.scrollTop = chatBox.scrollHeight;
    }

    function speak(text) {
        window.speechSynthesis.cancel();
        const utterance = new SpeechSynthesisUtterance(text);
        window.speechSynthesis.speak(utterance);
    }

    function toggleSearch() {
        const bar = document.getElementById('search-bar');
        bar.style.display = bar.style.display === 'block' ? 'none' : 'block';
    }

    function toggleTheme() {
        document.body.classList.toggle('light-mode');
        themeToggle.classList.toggle('fa-sun');
    }

    input.addEventListener("keypress", (e) => { if(e.key === "Enter") handleSend(); });
</script>

</body>
</html>