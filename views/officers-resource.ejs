<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Strategic Resource Map | KumbhVerse AI</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <style>
        :root { 
            --kumbh-orange: #ff6a00; 
            --bg-dark: #070708; 
            --sidebar-bg: #0d0d0f;
            --card-glass: rgba(255, 255, 255, 0.03);
            --border-glass: rgba(255, 255, 255, 0.08);
            --premium-blue: #00d2ff;
        }
        
        body { background: var(--bg-dark); color: white; font-family: 'Plus Jakarta Sans', sans-serif; overflow-x: hidden; }
        
        /* Sidebar Styles */
        .sidebar { 
            width: 260px; height: 100vh; background: var(--sidebar-bg); 
            position: fixed; border-right: 1px solid var(--border-glass); 
            padding: 25px 15px; z-index: 1000;
        }
        .nav-item {
            color: rgba(255,255,255,0.5); text-decoration: none; padding: 12px 18px;
            border-radius: 12px; margin-bottom: 5px; display: flex; align-items: center;
            gap: 12px; transition: 0.3s; font-size: 0.95rem;
        }
        .nav-item:hover, .nav-item.active { background: rgba(255, 106, 0, 0.1); color: var(--kumbh-orange); }

        .main-content { margin-left: 260px; padding: 35px; }

        /* Card Styles */
        .module-card {
            background: var(--card-glass); border: 1px solid var(--border-glass);
            border-radius: 24px; padding: 25px; backdrop-filter: blur(10px); height: 100%;
            transition: 0.3s;
        }
        .module-card:hover { border-color: rgba(255, 106, 0, 0.3); }

        .stat-value { font-size: 1.8rem; font-weight: 800; color: var(--kumbh-orange); }

        /* Premium Map UI */
        .map-container-premium {
            height: 450px; background: radial-gradient(circle at center, #111 0%, #050505 100%);
            border-radius: 24px; border: 1px solid var(--border-glass);
            position: relative; overflow: hidden;
            background-image: linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px), 
                              linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
            background-size: 30px 30px;
        }

        .map-radar-ring {
            position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
            width: 300px; height: 300px; border: 1px solid rgba(0, 210, 255, 0.1);
            border-radius: 50%; animation: radar-pulse 4s infinite linear;
        }

        @keyframes radar-pulse {
            0% { width: 0; height: 0; opacity: 1; }
            100% { width: 600px; height: 600px; opacity: 0; }
        }

        .unit-marker {
            position: absolute; width: 12px; height: 12px; border-radius: 50%;
            cursor: pointer; transition: 0.3s;
        }
        .unit-marker:hover { transform: scale(1.5); box-shadow: 0 0 15px currentColor; }

        /* Resource Indicators */
        .resource-indicator {
            display: flex; align-items: center; gap: 12px;
            padding: 12px; background: rgba(255,255,255,0.04);
            border-radius: 14px; margin-bottom: 12px; border: 1px solid transparent;
            transition: 0.3s;
        }
        .resource-indicator:hover { border-color: var(--border-glass); background: rgba(255,255,255,0.07); }

        .status-badge { width: 8px; height: 8px; border-radius: 50%; }
        .bg-online { background-color: #2ecc71; box-shadow: 0 0 10px #2ecc71; }
        .bg-patrol { background-color: #f1c40f; box-shadow: 0 0 10px #f1c40f; }
        .bg-flying { background-color: var(--premium-blue); box-shadow: 0 0 10px var(--premium-blue); }

        /* Premium Buttons */
        .btn-premium {
            background: linear-gradient(45deg, var(--kumbh-orange), #ff8c00);
            border: none; color: white; transition: 0.3s; box-shadow: 0 4px 15px rgba(255, 106, 0, 0.2);
        }
        .btn-premium:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(255, 106, 0, 0.4); color: white; }
    </style>
</head>
<body>

<div class="sidebar">
    <div class="d-flex align-items-center gap-2 mb-5 px-3">
        <div style="width:30px; height:30px; background:var(--kumbh-orange); border-radius:8px;"></div>
        <h4 class="m-0 fw-bold">KumbhVerse</h4>
    </div>
    
    <nav>
        <div class="small text-uppercase text-muted mb-3 px-3">Core Control</div>
        <a href="/officer-dashboard" class="nav-item"><i class="fa-solid fa-chart-line"></i> Dashboard</a>
        <a href="/officer-crowd" class="nav-item"><i class="fa-solid fa-users"></i> Crowd Control</a>
        <a href="/officer-route" class="nav-item"><i class="fa-solid fa-map-location-dot"></i> Route & Traffic</a>
        
        <div class="small text-uppercase text-muted mt-4 mb-3 px-3">Emergency</div>
        <a href="/officer-medical-camp" class="nav-item"><i class="fa-solid fa-truck-medical"></i> Medical Camp</a>
        <a href="/officer-missing" class="nav-item"><i class="fa-solid fa-person-circle-exclamation"></i> Missing Portal</a>
        
        <div class="small text-uppercase text-muted mt-4 mb-3 px-3">Operations</div>
        <a href="/officer-seva" class="nav-item"><i class="fa-solid fa-calendar-check"></i> Seva Monitoring</a>
        <a href="/officer-resource" class="nav-item active"><i class="fa-solid fa-user-shield"></i> Resource Map</a>
        
        <a href="/logout" class="nav-item text-danger mt-5"><i class="fa-solid fa-power-off"></i> Logout</a>
    </nav>
</div>

<div class="main-content">
    <div class="d-flex justify-content-between align-items-end mb-5">
        <div>
            <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 mb-2 px-3">Live Operations</span>
            <h2 class="fw-bold m-0">Strategic Resource Map</h2>
            <p class="text-muted m-0">Operational Sector: <%= assignedZone %></p>
        </div>
        <div class="text-end">
            <button onclick="window.print()" class="btn btn-outline-light btn-sm px-4 py-2 border-opacity-25">
                <i class="fa-solid fa-file-pdf me-2"></i>EXPORT LOGS
            </button>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="module-card text-center">
                <small class="text-muted">Police Units</small>
                <div class="stat-value">84</div>
                <div class="text-success small mt-2"><i class="fa-solid fa-circle-check me-1"></i> Active Deployed</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="module-card text-center">
                <small class="text-muted">Drone Assets</small>
                <div class="stat-value text-info">06</div>
                <div class="text-info small mt-2"><i class="fa-solid fa-wind me-1"></i> High Altitude</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="module-card text-center">
                <small class="text-muted">CCTV Monitoring</small>
                <div class="stat-value text-warning">245</div>
                <div class="text-warning small mt-2"><i class="fa-solid fa-eye me-1"></i> AI Stream Active</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="module-card text-center">
                <small class="text-muted">Barricades</small>
                <div class="stat-value text-primary">112</div>
                <div class="text-muted small mt-2"><i class="fa-solid fa-lock me-1"></i> Sector Secured</div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-md-8">
            <div class="module-card p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h5 class="fw-bold m-0"><i class="fa-solid fa-satellite me-2 text-primary"></i>Tactical Grid View</h5>
                    <span class="badge rounded-pill bg-dark border border-secondary px-3">Live GPS Enabled</span>
                </div>
                
                <div class="map-container-premium" id="tactical-grid">
                    <div class="map-radar-ring"></div>
                    <div class="unit-marker bg-success" style="top:30%; left:40%;" onclick="showUnitDetail('QRT Unit 1')"></div>
                    <div class="unit-marker bg-info" style="top:60%; left:20%;" onclick="showUnitDetail('Drone Alpha')"></div>
                    <div class="unit-marker bg-warning" style="top:45%; left:75%;" onclick="showUnitDetail('Mounted Squad')"></div>
                    <div class="unit-marker bg-danger" style="top:80%; left:55%;" onclick="showUnitDetail('Emergency Med-Unit')"></div>

                    <div class="position-absolute bottom-0 start-0 p-3 w-100 bg-dark bg-opacity-50">
                        <small class="text-muted"><i class="fa-solid fa-location-crosshairs me-2"></i>Scanning Sector <%= assignedZone %> coordinates... 19.9975° N, 73.7898° E</small>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="module-card p-4">
                <h6 class="fw-bold mb-4 text-uppercase letter-spacing-1">Resource Status</h6>
                
                <div class="resource-indicator">
                    <div class="status-badge bg-online"></div>
                    <div class="flex-grow-1">
                        <div class="small fw-bold">Quick Response Team</div>
                        <small class="text-muted">Zone A-2 | Ready</small>
                    </div>
                    <i class="fa-solid fa-chevron-right text-muted small"></i>
                </div>

                <div class="resource-indicator">
                    <div class="status-badge bg-online"></div>
                    <div class="flex-grow-1">
                        <div class="small fw-bold">Traffic Squad 04</div>
                        <small class="text-muted">Main Junction | Active</small>
                    </div>
                    <i class="fa-solid fa-chevron-right text-muted small"></i>
                </div>

                <div class="resource-indicator">
                    <div class="status-badge bg-patrol"></div>
                    <div class="flex-grow-1">
                        <div class="small fw-bold">Mounted Patrol</div>
                        <small class="text-muted">River Bank | Patrolling</small>
                    </div>
                    <i class="fa-solid fa-chevron-right text-muted small"></i>
                </div>

                <div class="resource-indicator">
                    <div class="status-badge bg-flying"></div>
                    <div class="flex-grow-1">
                        <div class="small fw-bold">AI Drone Surveillance</div>
                        <small class="text-muted">Ram Kund | In-Air</small>
                    </div>
                    <i class="fa-solid fa-chevron-right text-muted small"></i>
                </div>

                <button onclick="premiumReassign()" class="btn btn-premium w-100 fw-bold mt-3 py-3 rounded-4">
                    <i class="fa-solid fa-shuffle me-2"></i>TRIGGER RE-ASSIGNMENT
                </button>
            </div>
        </div>
    </div>
</div>

<script>
    // 1. Premium Popup for Re-assignment using SweetAlert2
    function premiumReassign() {
        Swal.fire({
            title: 'Initiate Strategic Re-assignment?',
            text: "This will alert all unit commanders in <%= assignedZone %> sector.",
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ff6a00',
            cancelButtonColor: 'rgba(255,255,255,0.1)',
            confirmButtonText: 'Yes, Deploy Protocol',
            background: '#0d0d0f',
            color: '#fff',
            customClass: {
                popup: 'module-card',
                confirmButton: 'btn btn-warning px-4 py-2',
                cancelButton: 'btn btn-outline-light px-4 py-2'
            }
        }).then((result) => {
            if (result.isConfirmed) {
                Swal.fire({
                    title: 'Protocol Active',
                    text: 'Resource window is now open for relocation.',
                    icon: 'success',
                    background: '#0d0d0f',
                    color: '#fff',
                    confirmButtonColor: '#ff6a00'
                });
                document.getElementById('tactical-grid').style.borderColor = "#ff6a00";
            }
        });
    }

    // 2. Unit Detail Popup
    function showUnitDetail(unitName) {
        Swal.fire({
            title: unitName,
            html: `
                <div class="text-start mt-3">
                    <p class="small mb-1 text-muted">Personnel: 12 Officers</p>
                    <p class="small mb-1 text-muted">Hardware: GPS Bodycams</p>
                    <p class="small text-muted">Last Ping: 2 seconds ago</p>
                    <div class="progress bg-dark mt-2" style="height: 5px;">
                        <div class="progress-bar bg-warning" style="width: 85%"></div>
                    </div>
                </div>
            `,
            background: '#0d0d0f',
            color: '#fff',
            showConfirmButton: false,
            timer: 2000
        });
    }

    // 3. Grid Refresh Effect
    setInterval(() => {
        const grid = document.getElementById('tactical-grid');
        grid.style.opacity = "0.8";
        setTimeout(() => grid.style.opacity = "1", 100);
    }, 5000);
</script>

</body>
</html>