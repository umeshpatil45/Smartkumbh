<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Live Tracking | Kumbh Wheels</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --primary: #00e676; 
            --secondary: #2979ff; 
            --dark: #050508;
            --glass: rgba(28, 28, 36, 0.9);
        }

        body, html { margin: 0; padding: 0; height: 100%; overflow: hidden; background: var(--dark); font-family: 'Plus Jakarta Sans', sans-serif; }

        /* Map styling */
        #map { height: 100vh; width: 100vw; position: absolute; z-index: 1; }
        .leaflet-tile-pane { filter: invert(100%) hue-rotate(180deg) brightness(95%) contrast(90%); }

        /* Floating UI Elements */
        .overlay { position: absolute; width: 100%; z-index: 1000; pointer-events: none; }
        .header { top: 0; padding: 25px; background: linear-gradient(to bottom, rgba(0,0,0,0.8), transparent); display: flex; align-items: center; justify-content: space-between; pointer-events: auto; }
        .footer { bottom: 0; padding: 20px; pointer-events: auto; }

        /* Glassmorphism Card */
        .status-card {
            background: var(--glass); backdrop-filter: blur(15px);
            border: 1px solid rgba(255,255,255,0.1); border-radius: 24px;
            padding: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        }

        .back-btn {
            width: 45px; height: 45px; background: var(--glass);
            border-radius: 12px; display: flex; align-items: center; justify-content: center;
            border: 1px solid rgba(255,255,255,0.1); cursor: pointer; color: white;
        }

        /* Pulse Animation for Live Location */
        .user-pulse {
            width: 20px; height: 20px; background: var(--secondary);
            border: 3px solid white; border-radius: 50%;
            position: relative; box-shadow: 0 0 15px var(--secondary);
        }
        .user-pulse::after {
            content: ''; position: absolute; width: 100%; height: 100%;
            border-radius: 50%; background: var(--secondary);
            animation: pulse 2s infinite; opacity: 0.5;
        }

        @keyframes pulse {
            0% { transform: scale(1); opacity: 0.5; }
            100% { transform: scale(3); opacity: 0; }
        }

        .btn-main {
            background: linear-gradient(90deg, var(--secondary), #00d2ff);
            border: none; border-radius: 15px; padding: 15px;
            width: 100%; color: white; font-weight: 800; margin-top: 15px;
            text-transform: uppercase; letter-spacing: 1px;
            transition: 0.3s;
        }
        .btn-main:active { transform: scale(0.95); }

        .live-tag {
            background: rgba(0, 230, 118, 0.2); color: var(--primary);
            padding: 4px 12px; border-radius: 20px; font-size: 10px; font-weight: 800;
        }

        /* UNIQUE RIDE SEARCH MODAL */
        .search-modal {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.8); backdrop-filter: blur(10px);
            z-index: 2000; display: none; align-items: center; justify-content: center;
        }

        .modal-content-custom {
            background: var(--glass); border: 1px solid rgba(255,255,255,0.1);
            padding: 40px; border-radius: 30px; text-align: center; width: 85%; max-width: 400px;
        }

        .radar {
            width: 100px; height: 100px; border: 2px solid var(--primary);
            border-radius: 50%; margin: 0 auto 25px; position: relative;
            animation: radar-beam 2s linear infinite;
        }
        .radar::before {
            content: ''; position: absolute; top: 50%; left: 50%;
            width: 10px; height: 10px; background: var(--primary);
            border-radius: 50%; transform: translate(-50%, -50%);
            box-shadow: 0 0 20px var(--primary);
        }

        @keyframes radar-beam {
            0% { box-shadow: 0 0 0 0px rgba(0, 230, 118, 0.5); }
            100% { box-shadow: 0 0 0 50px rgba(0, 230, 118, 0); }
        }

        .loading-dots:after {
            content: ' .';
            animation: dots 1.5s steps(5, end) infinite;
        }
        @keyframes dots {
            0%, 20% { color: rgba(0,0,0,0); text-shadow: .2em 0 0 rgba(0,0,0,0), .4em 0 0 rgba(0,0,0,0); }
            40% { color: white; text-shadow: .2em 0 0 rgba(0,0,0,0), .4em 0 0 rgba(0,0,0,0); }
            60% { text-shadow: .2em 0 0 white, .4em 0 0 rgba(0,0,0,0); }
            80%, 100% { text-shadow: .2em 0 0 white, .4em 0 0 white; }
        }
    </style>
</head>
<body>

    <div id="map"></div>

    <div class="overlay header">
        <div class="back-btn" onclick="window.history.back()">
            <i class="fas fa-chevron-left"></i>
        </div>
        <div class="text-center">
            <span class="live-tag"><i class="fas fa-satellite-dish fa-spin"></i> LIVE GPS</span>
            <h6 class="text-white mb-0 mt-1 fw-bold">Kumbh Wheels Tracking</h6>
        </div>
        <div class="back-btn" onclick="locateUser()">
            <i class="fas fa-location-crosshairs"></i>
        </div>
    </div>

    <div class="overlay footer">
        <div class="status-card">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div class="d-flex align-items-center">
                    <div class="user-pulse me-3"></div>
                    <div>
                        <small class="text-secondary d-block">Your Location</small>
                        <span id="current-addr" class="text-white fw-bold">Searching...</span>
                    </div>
                </div>
            </div>
            
            <div style="border-left: 2px dashed #333; margin-left: 9px; height: 20px;"></div>
            
            <div class="d-flex align-items-center mt-2">
                <i class="fas fa-map-marker-alt text-danger me-3" style="font-size: 20px; margin-left: 3px;"></i>
                <div class="w-100">
                    <input type="text" class="bg-transparent border-0 text-white w-100" placeholder="Where to?">
                </div>
            </div>

            <button class="btn-main" onclick="startBooking()">CONFIRM PICKUP</button>
        </div>
    </div>

    <div id="searchModal" class="search-modal">
        <div class="modal-content-custom">
            <div id="modalBody">
                <div class="radar"></div>
                <h4 class="text-white fw-bold mb-2">Finding Rides</h4>
                <p class="text-secondary mb-4">Searching for available drivers near Nashik<span class="loading-dots"></span></p>
                <button class="btn btn-outline-light rounded-pill px-4 btn-sm" onclick="closeModal()">CANCEL</button>
            </div>
        </div>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        const map = L.map('map', { zoomControl: false }).setView([19.9975, 73.7898], 15);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png').addTo(map);

        const userIcon = L.divIcon({
            className: 'custom-user-icon',
            html: '<div class="user-pulse"></div>',
            iconSize: [20, 20]
        });

        const carIcon = L.divIcon({
            className: 'car-icon',
            html: '<i class="fas fa-car-side" style="color:#00e676; font-size:22px; filter: drop-shadow(0 0 5px #000);"></i>',
            iconSize: [25, 25]
        });

        let userMarker = L.marker([19.9975, 73.7898], { icon: userIcon }).addTo(map);

        function locateUser() {
            if ("geolocation" in navigator) {
                navigator.geolocation.watchPosition((position) => {
                    const lat = position.coords.latitude;
                    const lon = position.coords.longitude;
                    const newPos = [lat, lon];
                    userMarker.setLatLng(newPos);
                    map.flyTo(newPos, 16);
                    
                    fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}`)
                        .then(res => res.json())
                        .then(data => {
                            document.getElementById('current-addr').innerText = data.display_name.split(',')[0] + ", Nashik";
                        });
                }, (error) => {
                    alert("Please enable GPS/Location Services!");
                }, { enableHighAccuracy: true });
            }
        }

        // Mock Drivers
        const driverCoords = [[20.0010, 73.7920], [19.9940, 73.7850], [19.9990, 73.7800]];
        driverCoords.forEach(coord => {
            let m = L.marker(coord, { icon: carIcon }).addTo(map);
            setInterval(() => {
                let current = m.getLatLng();
                m.setLatLng([current.lat + 0.0001, current.lng + 0.0001]);
            }, 3000);
        });

        // MODAL FUNCTIONS
        function startBooking() {
            document.getElementById('searchModal').style.display = 'flex';
            
            // Simulation: Success message after 5 seconds
            setTimeout(() => {
                const modalBody = document.getElementById('modalBody');
                modalBody.innerHTML = `
                    <div class="mb-3"><i class="fas fa-check-circle text-success" style="font-size: 60px;"></i></div>
                    <h4 class="text-white fw-bold">Ride Found!</h4>
                    <p class="text-secondary">Vehicle: MH 15 AB 1234<br>Driver 'Rahul' is on the way.</p>
                    <button class="btn-main" onclick="location.reload()">OKAY</button>
                `;
            }, 5000);
        }

        function closeModal() {
            document.getElementById('searchModal').style.display = 'none';
        }

        window.onload = locateUser;
    </script>
</body>
</html>