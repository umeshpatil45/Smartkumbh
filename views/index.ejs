                <div class="row g-0">
                    <div class="col-md-4 p-5 d-flex flex-column justify-content-center">
                        <h2 class="fw-bold mb-3">LIVE SYNC MAP</h2>
                        <p class="opacity-75">Navigate Nashik with real-time traffic updates, Ghat locations, and emergency zones.</p>
                        <button class="btn btn-outline-warning rounded-pill mt-3" onclick="handleNav('Expanding Interactive Map...')">EXPAND MAP</button>
                    </div>
                    <div class="col-md-8 position-relative bg-dark" style="min-height: 400px;">
                        <div class="position-absolute top-50 start-50 translate-middle text-center" style="z-index: 2;">
