<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KumbhVerse | Nashik 2027 AI Portal</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    
    <style>
        :root { --kumbh-orange: #ff6a00; --kumbh-gold: #ffb400; --bg-dark: #050506; }
        
        body { 
            background: var(--bg-dark); color: #ffffff;
            font-family: 'Inter', sans-serif;
            overflow-x: hidden;
        }

        .hero-viewport {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -2;
            background: linear-gradient(rgba(0,0,0,0.7), rgba(0,0,0,0.7)), url('images/background.png'); 
            background-size: cover; background-position: center;
        }
        
        .mesh-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: -1;
            background: radial-gradient(circle at 50% 50%, rgba(255, 106, 0, 0.1) 0%, rgba(5, 5, 6, 0.95) 80%);
        }

        .feature-card {
            background: rgba(255, 255, 255, 0.05); border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 24px; padding: 30px; cursor: pointer;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            position: relative; overflow: hidden; height: 100%;
        }
        .feature-card:hover {
            background: rgba(255, 255, 255, 0.08); transform: translateY(-10px);
            border-color: var(--kumbh-orange);
        }

        .side-dock {
            position: fixed; right: 20px; top: 50%; transform: translateY(-50%);
            display: flex; flex-direction: column; gap: 15px; z-index: 1000;
        }
        .dock-item {
            width: 50px; height: 50px; background: rgba(255,255,255,0.1);
            backdrop-filter: blur(10px); border: 1px solid rgba(255,255,255,0.1);
            border-radius: 12px; display: flex; align-items: center; justify-content: center;
            color: white; transition: 0.3s; text-decoration: none;
        }
        .dock-item:hover { background: var(--kumbh-orange); color: white; transform: scale(1.1); }

        .user-pill {
            background: rgba(255, 106, 0, 0.15); border: 1px solid var(--kumbh-orange);
            padding: 5px 15px; border-radius: 50px; display: flex; align-items: center; gap: 10px;
        }

       /* Modern Footer Styling */
        .main-footer {
            background: rgba(255, 255, 255, 0.02);
            backdrop-filter: blur(10px);
            border-top: 1px solid rgba(255, 255, 255, 0.1);
            padding: 80px 0 30px;
            margin-top: 100px;
            position: relative;
        }

        .footer-logo-text {
            font-size: 1.8rem;
            letter-spacing: 2px;
        }

        .footer-heading {
            color: var(--kumbh-orange);
            font-weight: 700;
            margin-bottom: 25px;
            text-transform: uppercase;
            font-size: 1.1rem;
        }

        .footer-links-list {
            list-style: none;
            padding: 0;
        }

        .footer-links-list li {
            margin-bottom: 12px;
        }

        .footer-links-list a {
            color: rgba(255, 255, 255, 0.6);
            text-decoration: none;
            transition: all 0.3s ease;
            display: inline-block;
        }

        .footer-links-list a:hover {
            color: var(--kumbh-gold);
            transform: translateX(8px);
        }

        .social-icons {
            display: flex;
            gap: 15px;
            margin-top: 20px;
        }

        .social-btn {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.05);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            transition: 0.4s;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .social-btn:hover {
            background: var(--kumbh-orange);
            color: white;
            transform: translateY(-5px);
            box-shadow: 0 5px 15px rgba(255, 106, 0, 0.4);
        }

        .newsletter-box {
            background: rgba(255, 255, 255, 0.05);
            padding: 20px;
            border-radius: 15px;
            border: 1px solid rgba(255, 255, 255, 0.1);
        }

        .back-to-top {
            position: absolute;
            top: -25px;
            left: 50%;
            transform: translateX(-50%);
            width: 50px;
            height: 50px;
            background: var(--kumbh-orange);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            box-shadow: 0 0 20px rgba(255, 106, 0, 0.5);
            cursor: pointer;
            transition: 0.3s;
        }

        .back-to-top:hover {
            background: var(--kumbh-gold);
            transform: translateX(-50%) translateY(-5px);
        }
        #live-toast {
            position: fixed; bottom: 30px; left: 30px; z-index: 2000;
            background: rgba(0, 0, 0, 0.8); backdrop-filter: blur(15px);
            border-left: 5px solid var(--kumbh-orange); border-radius: 10px;
            padding: 15px 25px; transform: translateX(-150%); transition: 0.5s ease;
        }
        #live-toast.show { transform: translateX(0); }

        .btn-warning { background: var(--kumbh-orange); border: none; color: white; }
        .btn-warning:hover { background: var(--kumbh-gold); color: black; }

        .modal-content {
            background: #111; color: white;
            border: 1px solid var(--kumbh-orange); border-radius: 20px;
        }
        .form-control {
            background: rgba(255,255,255,0.1); border: 1px solid rgba(255,255,255,0.1);
            color: white !important;
        }

@keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}

    </style>
</head>
<body>

