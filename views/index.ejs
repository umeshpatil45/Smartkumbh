    <main class="container">
        <div class="row min-vh-75 align-items-center py-5">
            <div class="col-lg-7">
                <span class="badge rounded-pill bg-light text-dark px-3 py-2 mb-3">AI-POWERED SMART PORTAL</span>
                <h1 class="display-2 fw-bold mb-4">REVOLUTIONIZING <br><span style="color:var(--kumbh-orange)">KUMBH 2027.</span></h1>
                <p class="lead opacity-75 mb-5">Nashik's official digital companion for the 2027 Kumbh Mela. Real-time updates on crowd, water quality, and safe stay.</p>
                <div class="d-flex gap-3">
                    <button class="btn btn-warning btn-lg rounded-pill px-5 shadow" onclick="handleNav('Exploring KumbhVerse...')">EXPLORE NOW</button>
                    <button class="btn btn-outline-light btn-lg rounded-pill px-4" onclick="handleNav('Loading Official Guidebook...')">GUIDEBOOK</button>
                </div>
            </div>
        </div>

        <div class="row g-4 mt-5">
            <div class="col-md-3">
                <div class="feature-card" onclick="handleNav('Analyzing High-Density Zones...')">
                    <i class="fa-solid fa-users text-warning fs-1 mb-3"></i>
                    <h5>Crowd Control</h5>
                    <p class="small opacity-50">Real-time density analysis</p>
                    <h3 class="m-0" id="crowd-count">94.2K <small class="fs-6 text-success">Active</small></h3>
                </div>
            </div>
            <div class="col-md-3">
