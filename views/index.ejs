    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Navigation Simulation with SweetAlert
        function handleNav(msg) {
            Swal.fire({
                title: 'KumbhVerse 2027',
                html: `<div class="text-center"><div class="spinner-border text-warning mb-3"></div><p>${msg}</p></div>`,
                timer: 1500,
                timerProgressBar: true,
                background: '#111',
                color: '#fff',
                showConfirmButton: false,
                didOpen: () => { Swal.showLoading(); }
            });
        }

        // Registration Logic
        document.getElementById('registerForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const phone = document.getElementById('regPhone').value;
            const name = document.getElementById('regName').value;
            const pass = document.getElementById('regPass').value;

            if(localStorage.getItem(phone)) {
                Swal.fire('Error', 'Account already exists!', 'error');
            } else {
                localStorage.setItem(phone, JSON.stringify({ name: name, pass: pass }));
                Swal.fire('Success', 'Account created successfully!', 'success');
                bootstrap.Modal.getInstance(document.getElementById('userRegisterModal')).hide();
            }
        });

        // Login Logic & UI Update
        document.getElementById('loginForm').addEventListener('submit', (e) => {
            e.preventDefault();
            const phone = document.getElementById('loginId').value;
            const inputPass = document.getElementById('loginPass').value;
            const user = JSON.parse(localStorage.getItem(phone));

            if(user && user.pass === inputPass) {
                Swal.fire('Welcome', 'Greetings, ' + user.name, 'success');
                updateDashboardUI(user.name);
                bootstrap.Modal.getInstance(document.getElementById('userLoginModal')).hide();
            } else {
                Swal.fire('Error', 'Invalid credentials!', 'error');
            }
        });

        // Function to show User Pill instead of Login buttons
        function updateDashboardUI(name) {
            const authSection = document.getElementById('auth-section');
            authSection.innerHTML = `
                <div class="dropdown">
                    <div class="user-pill dropdown-toggle" role="button" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false" style="cursor:pointer">
                        <i class="fa-solid fa-circle-user text-warning fs-5"></i>
                        <span class="fw-bold text-white small">${name.toUpperCase()}</span>
                    </div>
                    <ul class="dropdown-menu dropdown-menu-end dropdown-menu-dark" style="border: 1px solid var(--kumbh-orange); background: #111;">
                        <li><a class="dropdown-item" href="#">My Profile</a></li>
                        <li><hr class="dropdown-divider opacity-25"></li>
                        <li><a class="dropdown-item text-danger" href="javascript:void(0)" onclick="location.reload()">Logout</a></li>
                    </ul>
                </div>
            `;
        }

        // Live Crowd Update Simulation
        function updateLiveStats() {
            const crowdEl = document.getElementById('crowd-count');
            let count = 94.2;
            setInterval(() => {
                count += (Math.random() * 0.1);
                if(crowdEl) crowdEl.innerHTML = `${count.toFixed(1)}K <small class="fs-6 text-success">Active</small>`;
            }, 5000);
        }

        // Live Alerts Logic
        const toast = document.getElementById('live-toast');
        const toastMsg = document.getElementById('toast-msg');
        let messages = [
            "Ramkund: Moderate Crowds", 
            "Parking Tapovan: 20 Slots Left", 
            "Weather: 24°C Clear Sky",
            "Next Aarti: 6:30 PM at Ghat"
        ];
        let index = 0;
        function showToast() {
            if(toastMsg) toastMsg.innerText = messages[index];
            toast.classList.add('show');
            setTimeout(() => {
                toast.classList.remove('show');
                index = (index + 1) % messages.length;
            }, 4000);
        }

       // AI Assistant Toggle Logic
const aiBtn = document.getElementById('ai-btn');
const aiContainer = document.getElementById('ai-container');

aiBtn.addEventListener('click', (e) => {
    e.preventDefault();
    if (aiContainer.style.display === 'none') {
        aiContainer.style.display = 'block';
        // थोडं अ‍ॅनिमेशन देण्यासाठी
        aiContainer.style.animation = 'fadeInUp 0.5s ease forwards';
    } else {
        aiContainer.style.display = 'none';
    }
});



        window.onload = () => {
            updateLiveStats();
            setInterval(showToast, 7000);
            showToast();
        };
    </script>
</body>
