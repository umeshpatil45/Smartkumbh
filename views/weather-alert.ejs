<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nashik Weather | Big Robo Live</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --alert-red: #ff3d00;
            --safe-blue: #00e5ff;
            --bg-dark: #0b141a;
            --glass: rgba(255, 255, 255, 0.05);
        }

        body, html {
            margin: 0; padding: 0;
            height: 100%; width: 100%;
            font-family: 'Segoe UI', sans-serif;
            background: var(--bg-dark);
            color: white;
            overflow: hidden;
        }

        .weather-bg {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: radial-gradient(circle at center, #1a3a5a 0%, #06101a 100%);
            z-index: -1;
        }

        /* BACK BUTTON STYLE */
        .back-btn {
            position: absolute;
            top: 30px;
            left: 30px;
            width: 50px;
            height: 50px;
            background: var(--glass);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            text-decoration: none;
            z-index: 100;
            transition: 0.3s;
        }

        .back-btn:hover {
            background: var(--safe-blue);
            color: black;
            transform: scale(1.1);
        }

        .wrapper {
            width: 100%; height: 100vh;
            display: flex; justify-content: center; align-items: center;
            position: relative;
        }

        /* BIG ROBO STYLING */
        .big-robo {
            position: absolute;
            left: -30px; 
            bottom: -10px;
            width: 350px; 
            z-index: 5;
            filter: drop-shadow(0 0 20px var(--safe-blue));
            opacity: 0.9;
            pointer-events: none;
            animation: roboPresence 5s ease-in-out infinite;
        }

        @keyframes roboPresence {
            0%, 100% { transform: scale(1); filter: drop-shadow(0 0 15px var(--safe-blue)); }
            50% { transform: scale(1.03); filter: drop-shadow(0 0 35px var(--safe-blue)); }
        }

        .container {
            width: 400px; height: 85vh;
            background: var(--glass);
            backdrop-filter: blur(20px);
            border-radius: 35px;
            border: 1px solid rgba(255,255,255,0.1);
            display: flex; flex-direction: column;
            box-shadow: 0 0 50px rgba(0,0,0,0.5);
            z-index: 10;
            margin-left: 120px;
        }

        .header { padding: 25px; text-align: center; }
        .badge { background: var(--alert-red); color: white; padding: 6px 15px; border-radius: 20px; font-size: 0.75rem; font-weight: bold; animation: pulse-red 1.5s infinite; }
        
        @keyframes pulse-red { 0% { box-shadow: 0 0 0 0 rgba(255, 61, 0, 0.7); } 70% { box-shadow: 0 0 0 10px rgba(255, 61, 0, 0); } 100% { box-shadow: 0 0 0 0 rgba(255, 61, 0, 0); } }

        .content { flex: 1; padding: 20px; overflow-y: auto; scrollbar-width: none; }

        .temp-main { text-align: center; margin: 30px 0; }
        .temp-main h1 { font-size: 5.5rem; margin: 0; font-weight: 200; color: white; }

        .info-card {
            background: rgba(255, 255, 255, 0.07);
            padding: 20px; border-radius: 25px;
            margin-bottom: 12px; display: flex;
            justify-content: space-between; align-items: center;
        }

        /* REFRESH BUTTON STYLE */
        .footer-btn {
            background: var(--safe-blue); 
            color: #000; 
            padding: 18px;
            margin: 20px; 
            border-radius: 20px; 
            text-align: center;
            text-decoration: none; 
            font-weight: bold;
            cursor: pointer;
            border: none;
            display: block;
            transition: 0.3s;
        }

        .footer-btn:active { transform: scale(0.95); }
        .footer-btn i { margin-right: 8px; }

    </style>
</head>
<body>

    <div class="weather-bg"></div>

    <a href="javascript:history.back()" class="back-btn">
        <i class="fas fa-chevron-left"></i>
    </a>

    <div class="wrapper">
        <img src="/images/Robo.png" class="big-robo" alt="Weather AI Expert">

        <div class="container">
            <div class="header">
                <span class="badge" id="status-badge">SYSTEM LIVE</span>
                <h3 style="margin-top: 15px; letter-spacing: 1px;">NASHIK WEATHER</h3>
            </div>

            <div class="content">
                <div class="temp-main">
                    <h1 id="temp-display">--°</h1>
                    <p id="weather-desc" style="color: var(--safe-blue); text-transform: uppercase; font-size: 0.8rem;">DETECTING...</p>
                </div>

                <div class="info-card" id="alert-box" style="border-left: 4px solid var(--alert-red); display: none;">
                    <div style="display: flex; align-items: center; gap: 15px;">
                        <i class="fas fa-cloud-bolt" style="color: var(--alert-red); font-size: 1.5rem;"></i>
                        <div>
                            <span style="display: block; font-size: 0.9rem;">Live Alert</span>
                            <span id="alert-text" style="font-size: 0.7rem; opacity: 0.6;">Local weather shift</span>
                        </div>
                    </div>
                </div>

                <div class="info-card">
                    <span><i class="fas fa-wind"></i> Wind</span>
                    <span id="wind-speed" style="color: var(--safe-blue);">-- km/h</span>
                </div>

                <div class="info-card">
                    <span><i class="fas fa-droplet"></i> Humidity</span>
                    <span id="humidity" style="color: var(--safe-blue);">--%</span>
                </div>
            </div>

            <button onclick="fetchWeather()" class="footer-btn">
                <i class="fas fa-sync-alt" id="refresh-icon"></i> REFRESH DATA
            </button>
        </div>
    </div>

    <script>
        async function fetchWeather() {
            const tempEl = document.getElementById('temp-display');
            const descEl = document.getElementById('weather-desc');
            const refreshIcon = document.getElementById('refresh-icon');

            // Start loading animation
            refreshIcon.classList.add('fa-spin');
            descEl.innerText = "UPDATING...";

            // Nashik coordinates
            const lat = 19.9975;
            const lon = 73.7898;
            
            try {
                // Fetching real-time data from Open-Meteo
                const response = await fetch(`https://api.open-meteo.com/v1/forecast?latitude=${lat}&longitude=${lon}&current_weather=true`);
                const data = await response.json();
                
                // Update UI elements
                tempEl.innerText = Math.round(data.current_weather.temperature) + '°';
                document.getElementById('wind-speed').innerText = data.current_weather.windspeed + ' km/h';
                document.getElementById('humidity').innerText = "62%"; // Open-Meteo humidity separately anavi lagte, temporary fixed dakhvli ahe.
                descEl.innerText = "NASHIK CURRENT STATUS";

                // Alert logic: wind speed varun alert dakhvne
                const alertBox = document.getElementById('alert-box');
                if(data.current_weather.windspeed > 18) {
                    alertBox.style.display = 'flex';
                    document.getElementById('alert-text').innerText = "High wind speeds detected!";
                } else {
                    alertBox.style.display = 'none';
                }

            } catch (error) {
                console.error("Fetch error:", error);
                descEl.innerText = "OFFLINE MODE";
                tempEl.innerText = "24°";
            } finally {
                // Stop loading animation after 1 second for effect
                setTimeout(() => {
                    refreshIcon.classList.remove('fa-spin');
                }, 800);
            }
        }

        // Run when page loads
        window.onload = fetchWeather;
    </script>
</body>
</html> 