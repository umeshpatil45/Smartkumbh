<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KumbhVerse | Emergency Command</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary: #ff3333;
            --bg-dark: #050506;
            --sidebar-bg: #0c0c0e;
            --card-glass: rgba(255, 255, 255, 0.03);
            --border-glass: rgba(255, 255, 255, 0.08);
            --warning: #ffcc00;
            --accent-blue: #0084ff;
        }

        body {
            background-color: var(--bg-dark);
            color: #ffffff;
            font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0;
            display: flex;
            overflow-x: hidden;
        }

        /* --- UI Components --- */
        .sidebar { width: 260px; height: 100vh; background: var(--sidebar-bg); border-right: 1px solid var(--border-glass); position: fixed; padding: 30px 20px; z-index: 1000; }
        .brand-logo { font-size: 22px; font-weight: 800; color: #ff6a00; text-decoration: none; display: block; margin-bottom: 40px; }
        .nav-link { color: rgba(255,255,255,0.5); padding: 12px 15px; border-radius: 10px; display: flex; align-items: center; gap: 12px; text-decoration: none; margin-bottom: 8px; transition: 0.3s; }
        .nav-link.active { background: rgba(255, 51, 51, 0.1); color: var(--primary); }
        .nav-link:hover { color: white; background: rgba(255,255,255,0.05); }

        .main-content { margin-left: 260px; padding: 40px; width: calc(100% - 260px); min-height: 100vh; }

        .emergency-card {
            background: rgba(255, 51, 51, 0.02);
            border: 1px solid rgba(255, 51, 51, 0.15);
            border-radius: 24px;
            padding: 25px;
            height: 100%;
            backdrop-filter: blur(10px);
        }

        .sos-btn {
            background: linear-gradient(45deg, #ff3333, #990000);
            border: none;
            width: 100%;
            padding: 20px;
            color: white;
            font-weight: 800;
            font-size: 1.2rem;
            border-radius: 15px;
            box-shadow: 0 10px 20px rgba(255, 51, 51, 0.3);
            transition: 0.3s;
            cursor: pointer;
        }

        .sos-btn:hover { transform: translateY(-3px); box-shadow: 0 15px 30px rgba(255, 51, 51, 0.5); }

        .incident-item {
            background: var(--card-glass);
            border: 1px solid var(--border-glass);
            border-radius: 15px;
            padding: 15px;
            margin-bottom: 12px;
            border-left: 4px solid var(--primary);
            animation: slideIn 0.4s ease-out;
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateX(-10px); }
            to { opacity: 1; transform: translateX(0); }
        }

        #emergencyMap { height: 550px; border-radius: 24px; border: 1px solid var(--border-glass); z-index: 1; }

        /* --- NOTIFICATION SYSTEM --- */
        #notification-container {
            position: fixed;
            top: 30px;
            right: 30px;
            z-index: 9999;
            display: flex;
            flex-direction: column;
            gap: 15px;
            pointer-events: none;
        }

        .modern-alert {
            width: 350px;
            background: rgba(15, 15, 20, 0.9);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 18px;
            padding: 15px 20px;
            display: flex;
            align-items: center;
            gap: 15px;
            box-shadow: 0 20px 40px rgba(0,0,0,0.5);
            pointer-events: auto;
            position: relative;
            overflow: hidden;
            animation: alertShow 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275) forwards;
        }

        @keyframes alertShow {
            from { transform: translateX(120%); opacity: 0; }
            to { transform: translateX(0); opacity: 1; }
        }

        .alert-icon { width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        .alert-critical { background: rgba(255, 51, 51, 0.2); color: #ff3333; }
        .alert-warning { background: rgba(255, 204, 0, 0.2); color: #ffcc00; }
        .alert-info { background: rgba(0, 132, 255, 0.2); color: #0084ff; }

        .alert-progress { position: absolute; bottom: 0; left: 0; height: 3px; width: 100%; transform-origin: left; animation: progress linear forwards; }
        @keyframes progress { from { transform: scaleX(1); } to { transform: scaleX(0); } }

        /* --- CUSTOM MODAL --- */
        .custom-modal-overlay {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.8);
            backdrop-filter: blur(8px);
            display: none;
            align-items: center;
            justify-content: center;
            z-index: 10000;
            opacity: 0;
            transition: 0.3s;
        }

        .custom-modal {
            background: #111114;
            border: 1px solid var(--border-glass);
            border-radius: 28px;
            padding: 35px;
            max-width: 450px;
            width: 90%;
            text-align: center;
            transform: scale(0.9);
            transition: 0.3s;
        }

        .modal-icon {
            width: 70px; height: 70px; background: rgba(255, 51, 51, 0.1);
            color: var(--primary);
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 2rem; margin: 0 auto 20px;
        }

        .btn-modal { padding: 12px 25px; border-radius: 12px; font-weight: 700; transition: 0.2s; border: none; }
        .btn-confirm { background: var(--primary); color: white; }
        .btn-cancel { background: rgba(255,255,255,0.05); color: white; margin-right: 10px; }
        .btn-modal:hover { transform: translateY(-2px); opacity: 0.9; }

        .pulse-marker { background: #ff3333; border-radius: 50%; width: 15px; height: 15px; box-shadow: 0 0 0 rgba(255, 51, 51, 0.7); animation: pulse 1.5s infinite; }
        @keyframes pulse { 0% { box-shadow: 0 0 0 0 rgba(255, 51, 51, 0.7); } 70% { box-shadow: 0 0 0 15px rgba(255, 51, 51, 0); } 100% { box-shadow: 0 0 0 0 rgba(255, 51, 51, 0); } }
        .flash { animation: flash-anim 1.5s infinite; }
        @keyframes flash-anim { 0%, 100% { opacity: 1; } 50% { opacity: 0.3; } }
    </style>
</head>
<body>

    <div id="notification-container"></div>

    <div class="custom-modal-overlay" id="escalationModal">
        <div class="custom-modal">
            <div class="modal-icon"><i class="fa-solid fa-triangle-exclamation"></i></div>
            <h3 class="fw-800 mb-3">Escalate Alert?</h3>
            <p class="text-white-50 mb-4">This action will trigger a Global SOS and notify the District Command Center immediately.</p>
            <div class="d-flex justify-content-center">
                <button class="btn-modal btn-cancel" onclick="closeEscalationModal()">CANCEL</button>
                <button class="btn-modal btn-confirm" onclick="confirmGlobalSOS()">ESCALATE NOW</button>
            </div>
        </div>
    </div>

    <div class="sidebar">
        <a href="#" class="brand-logo">KUMBHVERSE</a>
     <nav>
            <a href="/admin-dashboard" class="nav-link"><i class="fa-solid fa-house"></i> Overview</a>
            <a href="/admin-officers" class="nav-link "><i class="fa-solid fa-shield-halved"></i> Security Officers</a>
            <a href="/admin-crowd" class="nav-link"><i class="fa-solid fa-users-viewfinder"></i> Crowd Analytics</a>
            <a href="/admin-alerts" class="nav-link active"><i class="fa-solid fa-tower-broadcast"></i> Emergency Broadcast</a>
            <div class="mt-5 pt-5">
                <a href="/logout" class="nav-link text-danger"><i class="fa-solid fa-power-off"></i> Logout</a>
            </div>
        </nav>
    </div>

    <div class="main-content">
        <div class="mb-5 d-flex justify-content-between align-items-center">
            <div>
                <h1 class="fw-800 m-0 text-danger">Emergency Command Centre</h1>
                <p class="text-white-50 mt-1"><i class="fa-solid fa-circle-dot flash text-danger me-2"></i> High Alert: Sector 4 - Ram Kund Monitoring</p>
            </div>
            <div class="d-flex gap-3">
                <button class="btn btn-warning rounded-pill px-4 fw-bold shadow-sm" onclick="dispatchUnit('Fire Squad')">Dispatch Fire Squad</button>
                <button class="btn btn-outline-danger rounded-pill px-4 fw-bold" onclick="openEscalationModal()">GLOBAL SOS</button>
            </div>
        </div>

        <div class="row g-4">
            <div class="col-lg-4">
                <div class="mb-4">
                    <button class="sos-btn" onclick="sendBroadcast()">
                        <i class="fa-solid fa-bullhorn me-2"></i> BROADCAST ALERT
                    </button>
                </div>

                <div class="emergency-card">
                    <div class="d-flex justify-content-between align-items-center mb-4">
                        <h5 class="fw-bold m-0"><i class="fa-solid fa-receipt me-2 text-danger"></i> Incident Feed</h5>
                        <span class="badge bg-danger rounded-pill">LIVE</span>
                    </div>
                    <div id="incidentFeed" style="max-height: 450px; overflow-y: auto; padding-right: 5px;">
                        </div>
                </div>
            </div>

            <div class="col-lg-8">
                <div id="emergencyMap"></div>
            </div>
        </div>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        // Map Initialization
        const map = L.map('emergencyMap', { zoomControl: false }).setView([19.9935, 73.7915], 16);
        L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png').addTo(map);

        const createPulseIcon = () => L.divIcon({
            className: 'pulse-icon-wrapper',
            html: `<div class="pulse-marker"></div>`,
            iconSize: [15, 15],
            iconAnchor: [7, 7]
        });
        L.marker([19.9935, 73.7915], {icon: createPulseIcon()}).addTo(map);

        // --- CORE NOTIFICATION LOGIC ---
        function showNotification(title, message, type = 'CRITICAL') {
            const container = document.getElementById('notification-container');
            const alertDiv = document.createElement('div');
            
            const iconMap = { 'CRITICAL': 'fa-triangle-exclamation', 'WARNING': 'fa-bullhorn', 'INFO': 'fa-truck-fast' };
            const classMap = { 'CRITICAL': 'alert-critical', 'WARNING': 'alert-warning', 'INFO': 'alert-info' };
            const colorMap = { 'CRITICAL': '#ff3333', 'WARNING': '#ffcc00', 'INFO': '#0084ff' };

            const duration = 4500;
            alertDiv.className = `modern-alert`;
            alertDiv.innerHTML = `
                <div class="alert-icon ${classMap[type]}"><i class="fa-solid ${iconMap[type]}"></i></div>
                <div class="alert-content">
                    <div class="title" style="color: ${colorMap[type]}">${title}</div>
                    <div class="desc">${message}</div>
                </div>
                <div class="alert-progress" style="animation-duration: ${duration}ms; background: ${colorMap[type]}"></div>
            `;

            container.appendChild(alertDiv);
            setTimeout(() => {
                alertDiv.style.animation = 'alertShow 0.5s ease reverse forwards';
                setTimeout(() => alertDiv.remove(), 500);
            }, duration);
        }

        // --- CUSTOM MODAL ACTIONS ---
        function openEscalationModal() {
            const modal = document.getElementById('escalationModal');
            modal.style.display = 'flex';
            setTimeout(() => { modal.style.opacity = '1'; modal.querySelector('.custom-modal').style.transform = 'scale(1)'; }, 10);
        }

        function closeEscalationModal() {
            const modal = document.getElementById('escalationModal');
            modal.style.opacity = '0';
            modal.querySelector('.custom-modal').style.transform = 'scale(0.9)';
            setTimeout(() => { modal.style.display = 'none'; }, 300);
        }

        function confirmGlobalSOS() {
            closeEscalationModal();
            showNotification("GLOBAL SOS ACTIVE", "State Disaster Response Team (SDRT) has been notified.", "CRITICAL");
            addIncident("GLOBAL SOS", "Level 5 Command Protocol initiated.", "CRITICAL");
        }

        // --- INTERFACE ACTIONS ---
        function sendBroadcast() {
            showNotification("BROADCAST SENT", "Emergency instructions sent to 50,000+ active users.", "WARNING");
            addIncident("Sector Broadcast", "Evacuation path info pushed to mobile apps.", "WARNING");
        }

        function dispatchUnit(unit) {
            showNotification("UNIT DISPATCHED", `${unit} is rerouting to Ram Kund (ETA: 4 mins).`, "INFO");
            addIncident("Unit Dispatched", `${unit} responding to Sector 4 incident.`, "INFO");
        }

        function addIncident(title, desc, type) {
            const feed = document.getElementById('incidentFeed');
            const item = document.createElement('div');
            item.className = 'incident-item';
            
            const colorMap = { "WARNING": "var(--warning)", "INFO": "#0084ff", "CRITICAL": "var(--primary)" };
            const badgeClass = type === "WARNING" ? 'bg-warning text-dark' : (type === "INFO" ? 'bg-primary' : 'bg-danger');
            
            item.style.borderLeftColor = colorMap[type];
            item.innerHTML = `
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="badge ${badgeClass}">${type}</span>
                    <small class="text-white-50">Just now</small>
                </div>
                <div class="fw-bold text-white">${title}</div>
                <p class="small text-white-50 m-0 mt-1">${desc}</p>
            `;
            feed.prepend(item);
        }

        // Initialize with one data point
        addIncident("Medical Emergency", "Suspected heatstroke at Ram Kund. Unit 04 responding.", "CRITICAL");
    </script>
</body>
</html>