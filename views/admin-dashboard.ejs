<!DOCTYPE html>
<html lang="mr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>KumbhVerse AI | Master Control</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;600;800&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --primary: #ff6a00;
            --secondary: #ff0055;
            --accent: #00d2ff;
            --bg-dark: #050506;
            --sidebar-bg: #0c0c0e;
            --card-glass: rgba(255, 255, 255, 0.03);
            --border-glass: rgba(255, 255, 255, 0.08);
        }

        body {
            background-color: var(--bg-dark);
            color: #ffffff;
            font-family: 'Plus Jakarta Sans', sans-serif;
            margin: 0;
            display: flex;
            overflow-x: hidden;
        }

        /* --- Cyber Sidebar --- */
        .sidebar {
            width: 280px;
            height: 100vh;
            background: var(--sidebar-bg);
            border-right: 1px solid var(--border-glass);
            position: fixed;
            padding: 30px 20px;
            z-index: 1000;
        }

        .brand-logo {
            font-size: 24px;
            font-weight: 800;
            background: linear-gradient(to right, var(--primary), var(--secondary));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 40px;
            display: block;
            text-decoration: none;
        }

        .nav-link {
            color: rgba(255,255,255,0.5);
            padding: 14px 18px;
            border-radius: 16px;
            display: flex;
            align-items: center;
            gap: 15px;
            text-decoration: none;
            transition: 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            margin-bottom: 10px;
        }

        .nav-link:hover, .nav-link.active {
            background: rgba(255, 106, 0, 0.1);
            color: var(--primary);
            box-shadow: inset 0 0 10px rgba(255, 106, 0, 0.05);
        }

        /* --- Main Layout --- */
        .main-content {
            margin-left: 280px;
            width: calc(100% - 280px);
            padding: 40px;
        }

        /* --- Glass Cards --- */
        .premium-card {
            background: var(--card-glass);
            border: 1px solid var(--border-glass);
            border-radius: 28px;
            padding: 30px;
            backdrop-filter: blur(20px);
            transition: 0.3s;
        }

        .premium-card:hover {
            border-color: rgba(255, 106, 0, 0.3);
            box-shadow: 0 15px 35px rgba(0,0,0,0.5);
        }

        /* --- Stats Icons --- */
        .stat-icon {
            width: 50px;
            height: 50px;
            border-radius: 15px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            margin-bottom: 20px;
        }

        /* --- Action Buttons --- */
        .btn-action {
            padding: 8px 20px;
            border-radius: 12px;
            font-weight: 600;
            font-size: 13px;
            transition: 0.3s;
            border: none;
        }

        .btn-approve { background: linear-gradient(45deg, #2ecc71, #27ae60); color: white; }
        .btn-reject { background: rgba(255, 77, 77, 0.1); color: #ff4d4d; border: 1px solid rgba(255, 77, 77, 0.2); }

        .btn-action:hover { transform: translateY(-3px); box-shadow: 0 5px 15px rgba(0,0,0,0.3); }

        /* --- Table Styling --- */
        .cyber-table {
            width: 100%;
            border-collapse: separate;
            border-spacing: 0 12px;
        }

        .cyber-table tr {
            background: rgba(255,255,255,0.02);
            transition: 0.3s;
        }

        .cyber-table td {
            padding: 18px;
            border-top: 1px solid var(--border-glass);
            border-bottom: 1px solid var(--border-glass);
        }

        .cyber-table td:first-child { border-left: 1px solid var(--border-glass); border-top-left-radius: 15px; border-bottom-left-radius: 15px; }
        .cyber-table td:last-child { border-right: 1px solid var(--border-glass); border-top-right-radius: 15px; border-bottom-right-radius: 15px; }

        .status-badge {
            padding: 5px 12px;
            border-radius: 10px;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 1px;
            font-weight: 800;
        }
    </style>
</head>
<body>

    <div class="sidebar">
        <a href="#" class="brand-logo">KUMBHVERSE AI</a>
        
        <nav>
            <a href="/admin-dashboard" class="nav-link active"><i class="fa-solid fa-house-chimney-window"></i> Overview</a>
            <a href="/admin-officers" class="nav-link"><i class="fa-solid fa-shield-halved"></i> Security Officers</a>
            <a href="/admin-crowd" class="nav-link"><i class="fa-solid fa-users-viewfinder"></i> Crowd Analytics</a>
            <a href="/admin-alerts" class="nav-link"><i class="fa-solid fa-tower-broadcast"></i> Emergency Broadcast</a>
            <div class="mt-5 pt-5">
                <a href="/logout" class="nav-link text-danger"><i class="fa-solid fa-power-off"></i> Logout System</a>
            </div>
        </nav>
    </div>

    <div class="main-content">
        
        <div class="d-flex justify-content-between align-items-end mb-5">
            <div>
                <h1 class="fw-800 mb-2">Master Dashboard</h1>
                <p class="text-white-50">Welcome back, Administrator. System is running stable.</p>
            </div>
            <div class="premium-card py-2 px-4 d-flex align-items-center gap-3">
                <div class="text-end">
                    <div class="small text-white-50">System Status</div>
                    <div class="small fw-bold text-success">ONLINE</div>
                </div>
                <div class="avatar-circle" style="width: 40px; height: 40px; background: var(--primary); border-radius: 12px; display: flex; align-items: center; justify-content: center;">A</div>
            </div>
        </div>

        <div class="row g-4 mb-5">
            <div class="col-md-4">
                <div class="premium-card">
                    <div class="stat-icon" style="background: rgba(0, 210, 255, 0.1); color: var(--accent);"><i class="fa-solid fa-person-walking-luggage"></i></div>
                    <div class="text-white-50 small">Total Pilgrims Joined</div>
                    <h2 class="fw-800 m-0"><%= (typeof users !== 'undefined') ? users.length : 0 %></h2>
                </div>
            </div>
            <div class="col-md-4">
                <div class="premium-card">
                    <div class="stat-icon" style="background: rgba(255, 106, 0, 0.1); color: var(--primary);"><i class="fa-solid fa-user-shield"></i></div>
                    <div class="text-white-50 small">Active Field Officers</div>
                    <h2 class="fw-800 m-0">
                        <%= (typeof officers !== 'undefined') ? officers.filter(o => o.status === 'Approved').length : 0 %>
                    </h2>
                </div>
            </div>
            <div class="col-md-4">
                <div class="premium-card" style="border-left: 4px solid var(--secondary);">
                    <div class="stat-icon" style="background: rgba(255, 0, 85, 0.1); color: var(--secondary);"><i class="fa-solid fa-clock-rotate-left"></i></div>
                    <div class="text-white-50 small">Pending Approvals</div>
                    <h2 class="fw-800 m-0 text-warning">
                        <%= (typeof officers !== 'undefined') ? officers.filter(o => o.status !== 'Approved').length : 0 %>
                    </h2>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">
                <h4 class="fw-bold mb-4 d-flex align-items-center gap-2">
                    <i class="fa-solid fa-unlock-keyhole text-primary"></i> Pending Verifications
                </h4>
                <div class="premium-card">
                    <div class="table-responsive">
                        <table class="cyber-table">
                            <thead>
                                <tr class="text-white-50 small">
                                    <th>OFFICER PROFILE</th>
                                    <th>DEPARTMENT / ASSIGNMENT</th>
                                    <th>REQUEST STATUS</th>
                                    <th class="text-end">COMMANDS</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if(typeof officers !== 'undefined' && officers.length > 0) { %>
                                    <% officers.forEach(officer => { %>
                                        <% if(officer.status !== 'Approved') { %>
                                        <tr>
                                            <td>
                                                <div class="d-flex align-items-center gap-3">
                                                    <div style="width: 45px; height: 45px; background: #222; border-radius: 12px; display: flex; align-items: center; justify-content: center; border: 1px solid var(--border-glass);">
                                                        <%= (officer.name) ? officer.name.charAt(0) : 'O' %>
                                                    </div>
                                                    <div>
                                                        <div class="fw-bold"><%= officer.name || 'N/A' %></div>
                                                        <div class="small text-white-50"><%= officer.email %></div>
                                                    </div>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge bg-dark border border-secondary px-3 py-2 rounded-pill small">
                                                    <%= officer.department || 'On-Field' %>
                                                </span>
                                            </td>
                                            <td>
                                                <span class="status-badge" style="background: rgba(255, 193, 7, 0.1); color: #ffc107; border: 1px solid #ffc107;">AWAITING</span>
                                            </td>
                                            <td class="text-end">
                                                <form action="/admin-approve-officer/<%= officer._id %>" method="POST" style="display:inline;">
                                                    <button type="submit" class="btn-action btn-approve me-2">GRANT ACCESS</button>
                                                </form>
                                                <button class="btn-action btn-reject">DENY</button>
                                            </td>
                                        </tr>
                                        <% } %>
                                    <% }) %>
                                <% } else { %>
                                    <tr><td colspan="4" class="text-center py-5 text-white-50">No pending officer requests found.</td></tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div style="position: fixed; top: -10%; right: -10%; width: 500px; height: 500px; background: var(--primary); filter: blur(180px); opacity: 0.05; z-index: -1;"></div>
    <div style="position: fixed; bottom: -10%; left: -10%; width: 400px; height: 400px; background: var(--accent); filter: blur(150px); opacity: 0.05; z-index: -1;"></div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        socket.on('update_dashboard', () => {
            // Smooth refresh
            window.location.reload();
        });
    </script>
</body>
</html>